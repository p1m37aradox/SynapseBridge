# --- SynapseBridge Master Alias File (v0.0.6.2b) ---


# 1. Environment & Paths
export SB_VENV_PATH='/root/SynapseBridge_Root/venv/bin'
export SB_PALACE='/mnt/SynapseBridge/palace'
export SB_AI_OUT='/mnt/SynapseBridge/OllamaGenerated'
#export OLLAMA_HOST=0.0.0.0:11434

# Ollama Mobile Optimizations (Value = Max # Of Threads Allowes)
export OLLAMA_NUM_CTX=2048
export OLLAMA_NUM_PARALLEL=4


# --- AUTOMATED LOGIC PERMISSION ---
# This ensures that every time the environment is initialized,
# the logic scripts are granted execution rights automatically.
if [ -d "/mnt/SynapseBridge/scripts" ]; then
chmod +x /mnt/SynapseBridge/scripts/*.sh 2>/dev/null
fi

# 2. Navigation & Git

    #Activate SynapseBridge_Root Python3.13 Virtual Environment
    alias sb-venv-activate='source /root/SynapseBridge_Root/venv/bin/activate -- bash -c "source $HOME/storage/shared/SynapseBridge/scripts/.sb-env-master; exec bash"'

    #Shared 'User Local' Storage
    alias cd-bridge='cd /mnt/SynapseBridge'
    
    #Open-WebUI On Port 8090
    #alias sb-owui='open-webui serve --port 8090'
    
    #open-webui serve --port 8090
    
    #Debian and (venv)Debian SynapseBridge_Root
    alias cd-sbroot='cd ~/SynapseBridge_Root'
    
    #PYTHON MEMPALACE AND SITE FILES
    alias cd-short='cd ~/SynapseBridge_Root/venv/lib/python3.13/site-packages/mempalace'
        #because cdcdcdcdcdcd
    
    #Junk Drawer
    alias cd-bin='cd /mnt/Junk'
    
    #Termux bin/
    alias cd-troot='cd /usr/local/bin'
    
    #git Status of Project
    alias g-status='cd /mnt/SynapseBridge && git status'
    
    #Pull git repo
    #alias g-pull='cd /mnt/SynapseBridge && git pull origin local-qwen-gemma'
    
#####Memory & Logic (MemPalace / MCP)

    #Launches the SSE and HTTP Server w/MCP Tools
    alias sb-mcp='python3 /root/SynapseBridge_Root/scripts/.synapse_mcp.py'
    
    #Shorthand for mempalace mine
    alias sb-mine='$SB_VENV_PATH/mempalace --palace $SB_PALACE mine /mnt/SynapseBridge --wing "SynapseBridge-Main"'
    
    #Shorthand for mempalace wake-up
    alias sb-wake='$SB_VENV_PATH/mempalace wake-up'
    
    #Launches The Client and LLM
    alias sb-chat='python3 /mnt/SynapseBridge/scripts/client_bridge.py'
    
    alias dev='sb-init'
    
    
#---------------TOOLS---------------
#Makes a shadow copy of .synapse_mcp and puts it in the root.

# Update Edited Server File From Shared Zone To Root Zone:
alias sb-sync='cp /mnt/SynapseBridge/scripts/.synapse_mcp.py /root/SynapseBridge_Root/scripts/.synapse_mcp.py && echo \"✅ Root copy updated.\"'

# Makes a backup of default cli.py from mempalace
    alias cli-bkp='cp /root/SynapseBridge_Root/venv/lib/python3.13/site-packages/mempalace/cli.py /root/SynapseBridge_Root/venv/lib/python3.13/site-packages/mempalace/cli.py.bak'

# Executes the cli patch script.
    alias mempalace-cli-patch='chmod +x /mnt/SynapseBridge/scripts/scripts/.cli_patch.py
    python3 /mnt/SynapseBridge/scripts/.cli_patch.py'

# Revert the CLI to its original state
    alias cli-rstr='mv /root/SynapseBridge_Root/venv/lib/python3.13/site-packages/mempalace/cli.py.bak /root/SynapseBridge_Root/venv/lib/python3.13/site-packages/mempalace/cli.py'



# 4. Local AI (Ollama)

    alias sb-ollama='export OLLAMA_HOST=0.0.0.0:11434 && nohup ollama serve > /mnt/SynapseBridge/ollama.log 2>&1 &'
    
    alias sb-models='ollama list'
    
    alias sb-coder='ollama run qwen2.5:3b'
    
    alias sb-gemma='ollama run gemma:2b'
    
    alias sb-ai-flush='ollama gc && pkill -9 ollama'

