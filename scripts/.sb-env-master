# --- SynapseBridge Master Alias File (v0.0.5) ---

# 1. Environment & Paths
# Using absolute paths for proot stability
export SB_VENV_PATH='/root/SynapseBridge_Root/venv/bin'
export SB_PALACE='/mnt/SynapseBridge/palace'
export SB_AI_OUT='/mnt/SynapseBridge/OllamaGenerated'

# 2. Navigation & Git
alias sb-venv-activate='source /root/SynapseBridge_Root/venv/bin/activate'
alias cd-bridge='cd /mnt/SynapseBridge'
alias g-status='cd /mnt/SynapseBridge && git status'
alias g-pull='cd /mnt/SynapseBridge && git pull origin gemini-active'

# 3. Memory & Logic (MemPalace / MCP)
alias sb-mcp='$SB_VENV_PATH/mempalace-mcp --palace $SB_PALACE'
alias sb-mine='$SB_VENV_PATH/mempalace --palace $SB_PALACE mine /mnt/SynapseBridge --wing "SynapseBridge-Main"'
alias sb-wake='$SB_VENV_PATH/mempalace wake-up'

# 4. Local AI (Ollama)
alias sb-ollama='ollama serve > /dev/null 2>&1 &'
alias sb-models='ollama list'
alias sb-coder='ollama run qwen2.5:3b'
alias sb-gemma='ollama run gemma:2b'
alias sb-ai-flush='ollama gc && pkill ollama'

# 5. Bridge Communication & UI
alias sb-notify='bash /mnt/SynapseBridge/scripts/sb-notify.sh'
alias sb-clip='bash /mnt/SynapseBridge/scripts/sb-clip.sh'

# 6. Launch Command
# Note: Use this while in Termux to bridge into the Debian environment
alias synapse='proot-distro login debian --bind ~/storage/shared/SynapseBridge:/mnt/SynapseBridge -- bash /mnt/SynapseBridge/scripts/UI_main.sh'

# --- Logic Gate: Directory Protection ---
# This prevents 'Permission Denied' errors when sourcing in Termux 
# by checking if the mount point exists before attempting mkdir.
if [ -d "/mnt/SynapseBridge" ]; then
    mkdir -p "$SB_AI_OUT"
else
    # Fallback for Termux-side sourcing if needed
    # mkdir -p ~/storage/shared/SynapseBridge/OllamaGenerated 2>/dev/null
    :
fi

echo "🌉 Synapse Environment: ONLINE (v0.0.5-AI-Memory)"
